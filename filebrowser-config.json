# File Browser Configuration for StereoCrafter Integration

# Server configuration
port: 8080
baseURL: "/filebrowser"
log: "stdout"

# Authentication - SET VIA ENVIRONMENT VARIABLES IN PRODUCTION
# Use FB_USERNAME and FB_PASSWORD environment variables
# These defaults are for local development only
username: "stereocrafter"
password: "CHANGE_THIS_PASSWORD_BEFORE_DEPLOYMENT_12345"

# Root directory (mounted volumes from StereoCrafter)
root: "/srv"

# Database
database: "/database/filebrowser.db"

# Disable signup for security
signup: false

# Enable perm (permissions) for user management
perm:
  admin: true
  execute: true
  create: true
  rename: true
  modify: true
  delete: true
  share: true
  download: true

# Custom branding
branding:
  name: "StereoCrafter File Manager"
  files: "/config/branding"
  disableExternal: true